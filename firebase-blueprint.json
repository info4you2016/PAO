{
  "entities": {
    "Presentation": {
      "title": "Presentation",
      "description": "A collection of slides",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "course": { "type": "string", "description": "Group presentations by course name" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerId"]
    },
    "Slide": {
      "title": "Slide",
      "description": "A slide in the presentation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "order": { "type": "number" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "Markdown or HTML content" },
        "image": { "type": "string" },
        "bgColor": { "type": "string" }
      },
      "required": ["order", "title"]
    }
  },
  "firestore": {
    "/presentations/{presentationId}": {
      "schema": "Presentation",
      "description": "Collection of presentations"
    },
    "/presentations/{presentationId}/slides/{slideId}": {
      "schema": "Slide",
      "description": "Slides within a presentation"
    }
  }
}
